# App Configuration
APP_NAME="SecureWatch AI"
ENVIRONMENT="development"
DEBUG=true

# Database Configuration
# IMPORTANT: Change this to your actual database URL before running the application.
DATABASE_URL=postgresql+psycopg://securewatch_user:CHANGE_ME@localhost:5432/securewatch_db

# JWT Security Configuration
# IMPORTANT: Replace with a cryptographically strong random secret (minimum 32 characters).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# NEVER commit a real key to version control.
JWT_SECRET_KEY=CHANGE_ME_generate_a_strong_random_secret_of_at_least_32_characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
